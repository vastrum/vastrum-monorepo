{
  "name": "starknet-defi-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:lib": "(cd ../../../tooling/react-vastrum-lib && npm run build) && npm i",
    "build:lib:prod": "(cd ../../../tooling/react-vastrum-lib && npm run build:prod) && npm i",
    "build:wasm": "cd wasm && CARGO_TARGET_DIR=../../../../target-wasm wasm-pack build --dev --target bundler",
    "build:wasm:prod": "cd wasm && CARGO_TARGET_DIR=../../../../target-wasm wasm-pack build --target bundler",
    "build": "npm run build:lib && npm run build:wasm && vite build",
    "build:prod": "npm run build:lib:prod && npm run build:wasm:prod && tsc && vite build",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.13",
    "@vastrum/react-lib": "file:../../../tooling/react-vastrum-lib",
    "vite-plugin-wasm": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.2.2",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
