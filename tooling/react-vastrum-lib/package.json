{
  "name": "@vastrum/react-lib",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/vastrum-react-lib.js",
  "module": "./dist/vastrum-react-lib.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vastrum-react-lib.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:wasm": "cd wasm && CARGO_TARGET_DIR=../../../target-wasm wasm-pack build --dev --target bundler",
    "build:wasm:prod": "cd wasm && CARGO_TARGET_DIR=../../../target-wasm wasm-pack build --target bundler",
    "build": "npm i && npm run build:wasm && vite build",
    "build:prod": "npm i && npm run build:wasm:prod && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.2.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-wasm": "^3.5.0"
  }
}
